Model RequerimentsHotelAccessSystemFDR ; package SysADL.types { value type Int { } value type Boolean { } value type String { } value type Void { } value type Real { } value type WristbandID { } value type AccessRequest { } value type AccessResponse { } value type ReservationData { } value type GuestProfile { } value type AccessLog { } enum AccessStatus { Granted , Denied } datatype AccessEvent { attributes : wristbandID : WristbandID ; location : String ; timestamp : String ; status : AccessStatus ; } } Requirement AccessControlFR ( 1 ) { text = "\"The system must control guest access to hotel environments using a configured wristband.\"" Requirement ConfigureWristbandFR ( 1.2 ) { text = "\"The system must configure the wristband with the guest profile, including access permissions and validity dates.\"" satisfied by HotelAccessSystemComponents.WristbandConfiguratorCP ; derive ManageReservationFR ; } Requirement ValidateAccessFR ( 1.3 ) { text = "\"The system must validate the wristband at each access point and grant or deny access based on permissions and current time.\"" satisfied by HotelAccessSystemComponents.AccessControllerCP ; derive ConfigureWristbandFR ; } Requirement ManageReservationFR ( 1.1 ) { text = "\"The system must register guest reservations and define the authorized access period and environments.\"" satisfied by HotelAccessSystemComponents.ReservationManagerCP ; } Requirement RevokeAccessFR ( 1.4 ) { text = "\"The system must deactivate the wristband upon guest checkout, revoking all access permissions.\"" satisfied by HotelAccessSystemComponents.AccessControllerCP ; } Requirement LogAccessEventFR ( 1.5 ) { text = "\"The system must record all access attempts, including guest identity, location, timestamp, and result.\"" satisfied by HotelAccessSystemComponents.AccessLoggerCP ; } } Requirement QualityNFR ( 2 ) { text = "\"The system must satisfy fault tolerance, scalability, and security concerns.\"" Requirement FaultToleranceNFR ( 2.1 ) { text = "\"The system must remain operational in case of server failure, allowing access readers to work in offline mode using local cached authorizations.\"" satisfied by HotelAccessSystemComponents.BackupServerCP ; } Requirement ScalabilityNFR ( 2.2 ) { text = "\"The system must support expansion of the number of access points and guests without degradation of performance.\"" satisfied by HotelAccessSystemComponents.AccessControllerCP ; } Requirement SecurityNFR ( 2.3 ) { text = "\"The communication between wristbands and readers must be encrypted, and the access log must be immutable.\"" satisfied by HotelAccessSystemComponents.AuthorizationServerCP ; } Requirement AvailabilityNFR ( 2.4 ) { text = "\"The system must be in operation at all times, with a backup server assuming control in case of primary server failure." satisfied by HotelAccessSystemComponents.BackupServerCP ; } } package HotelAccessSystemPorts { import SysADL.types ; port def WristbandIDOPT { flow out WristbandID } port def WristbandIDIPT { flow in WristbandID } port def AccessRequestOPT { flow out AccessRequest } port def AccessRequestIPT { flow in AccessRequest } port def AccessResponseOPT { flow out AccessResponse } port def AccessResponseIPT { flow in AccessResponse } port def ReservationDataOPT { flow out ReservationData } port def ReservationDataIPT { flow in ReservationData } port def GuestProfileOPT { flow out GuestProfile } port def GuestProfileIPT { flow in GuestProfile } port def AccessLogOPT { flow out AccessLog } port def AccessLogIPT { flow in AccessLog } port def DoorCommandOPT { flow out AccessResponse } port def DoorCommandIPT { flow in AccessResponse } } package HotelAccessSystemComponents { import SysADL.types ; import HotelAccessSystemPorts ; import HotelAccessSystemConnectors ;
	component def HotelAccessSystemCP { configuration { components : wr : WristbandReaderCP { using ports : signal : WristbandIDOPT ; } el : ElectronicLockCP { using ports : command : DoorCommandIPT ; } rm : ReservationManagerCP { using ports : reservationOut : ReservationDataOPT ; } wc : WristbandConfiguratorCP { using ports : reservationIn : ReservationDataIPT ; profileOut : GuestProfileOPT ; } ac : AccessControllerCP { using ports : wristbandIn : WristbandIDIPT ; requestOut : AccessRequestOPT ; responseIn : AccessResponseIPT ; doorOut : DoorCommandOPT ; logOut : AccessLogOPT ; } as : AuthorizationServerCP { using ports : requestIn : AccessRequestIPT ; profileIn : GuestProfileIPT ; responseOut : AccessResponseOPT ; backupOut : AccessRequestOPT ; } al : AccessLoggerCP { using ports : logIn : AccessLogIPT ; } connectors : c1 : WristbandReadCN bindings signal = wristbandIn ; c2 : AuthRequestCN bindings requestOut = requestIn ; c3 : AuthResponseCN bindings responseOut = responseIn ; c4 : DoorControlCN bindings doorOut = command ; c5 : ReservationCN bindings reservationOut = reservationIn ; c6 : ProfileCN bindings profileOut = profileIn ; c7 : LogCN bindings logOut = logIn ; } } boundary
	component def WristbandReaderCP { ports : signal : WristbandIDOPT ; } boundary
	component def ElectronicLockCP { ports : command : DoorCommandIPT ; }
	component def ReservationManagerCP { ports : reservationOut : ReservationDataOPT ; }
	component def WristbandConfiguratorCP { ports : reservationIn : ReservationDataIPT ; profileOut : GuestProfileOPT ; }
	component def AccessControllerCP { ports : wristbandIn : WristbandIDIPT ; requestOut : AccessRequestOPT ; responseIn : AccessResponseIPT ; doorOut : DoorCommandOPT ; logOut : AccessLogOPT ; backupResponseIn : AccessResponseIPT ; }
	component def AuthorizationServerCP { ports : requestIn : AccessRequestIPT ; profileIn : GuestProfileIPT ; responseOut : AccessResponseOPT ; }
	component def BackupServerCP { ports : requestIn : AccessRequestIPT ; responseOut : AccessResponseOPT ; }
	component def AccessLoggerCP { ports : logIn : AccessLogIPT ; } } package HotelAccessSystemConnectors { import HotelAccessSystemPorts ; connector def WristbandReadCN { participants : ~ source : WristbandIDOPT ; ~ destination : WristbandIDIPT ; flows : WristbandID from source to destination } connector def AuthRequestCN { participants : ~ source : AccessRequestOPT ; ~ destination : AccessRequestIPT ; flows : AccessRequest from source to destination } connector def AuthResponseCN { participants : ~ source : AccessResponseOPT ; ~ destination : AccessResponseIPT ; flows : AccessResponse from source to destination } connector def DoorControlCN { participants : ~ source : DoorCommandOPT ; ~ destination : DoorCommandIPT ; flows : AccessResponse from source to destination } connector def ReservationCN { participants : ~ source : ReservationDataOPT ; ~ destination : ReservationDataIPT ; flows : ReservationData from source to destination } connector def ProfileCN { participants : ~ source : GuestProfileOPT ; ~ destination : GuestProfileIPT ; flows : GuestProfile from source to destination } connector def LogCN { participants : ~ source : AccessLogOPT ; ~ destination : AccessLogIPT ; flows : AccessLog from source to destination } }